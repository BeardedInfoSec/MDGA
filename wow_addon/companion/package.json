{
  "name": "mdga-companion",
  "version": "1.5.0",
  "description": "MDGA WoW Addon Companion — watches SavedVariables and syncs to server",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node index.js",
    "setup": "node index.js --setup",
    "build": "pkg . --targets node22-win-x64 --output dist/mdga-companion.exe --compress GZip"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0"
  },
  "pkg": {
    "scripts": [
      "setup.js",
      "lua-parser.js"
    ],
    "assets": []
  }
}
